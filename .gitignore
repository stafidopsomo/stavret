wp-config.php
wp-config-ddev.php

# ── wp-content: only track our custom theme ───────────────────
wp-content/uploads/
wp-content/upgrade/
wp-content/plugins/
wp-content/themes/twenty*/
wp-content/themes/index.php

# ── Theme: build output + dependencies ────────────────────────
wp-content/themes/stavret/node_modules/
# dist is committed so the laptop doesn't need npm to run the site
# wp-content/themes/stavret/assets/dist/

# ── DDEV (generated files — kept via .ddev/.gitignore) ────────
# .ddev/ is tracked (config.yaml, etc.) via its own ignore rules

# ── Database dumps ─────────────────────────────────────────────
*.sql
*.sql.gz
# but allow the database/ folder dump for laptop setup
!database/
!database/*.sql.gz

# ── macOS ──────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverrideIcon

# ── Editor ─────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Node ───────────────────────────────────────────────────────
npm-debug.log*
